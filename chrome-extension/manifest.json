{
  "manifest_version": 3,
  "name": "NeonFrame",
  "version": "1.0.0",
  "description": "Generate AI images for Instagram — cyberpunk, anime, 3D and more.",
  "permissions": ["storage", "clipboardWrite"],
  "host_permissions": [
    "https://neon-frame-delta.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NeonFrame — AI Image Generator"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
